  "editor.fontFamily": "Ubuntu Mono",
  "editor.fontSize": 16,
  "workbench.fontAliasing": "antialiased",
  "editor.fontLigatures": true,
  "editor.fontWeight": "300",
  "window.zoomLevel": 1,
  "editor.letterSpacing": 2,
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.venv": true
  }
}